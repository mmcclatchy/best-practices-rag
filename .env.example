# Dev container uses port 7688 to avoid collision with the released install (7687)
NEO4J_URI=bolt://localhost:7688
NEO4J_USERNAME=neo4j

# Credentials live in secrets/ as individual files:
#   secrets/neo4j_password   — auto-generated during setup
#   secrets/exa_api_key      — required, get a key at https://exa.ai/
