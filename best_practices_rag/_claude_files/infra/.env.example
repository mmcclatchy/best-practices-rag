# Non-sensitive connection config — copy to .env and edit as needed
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
INFERENCE_BASE_URL=https://api.fireworks.ai/inference/v1
INFERENCE_EXTRACT_MODEL=accounts/fireworks/models/gpt-oss-20b
INFERENCE_GAP_MODEL=accounts/fireworks/models/gpt-oss-120b
INFERENCE_SYNTHESIS_MODEL=accounts/fireworks/models/kimi-k2p5

# Sensitive values are loaded from the secrets/ directory (gitignored), not .env.
# Create these files before starting:
#
#   secrets/neo4j_password   → the Neo4j password (plain string)
#   secrets/neo4j_auth       → Neo4j auth in user/password format, e.g. neo4j/mypassword
#   secrets/exa_api_key      → your Exa API key
#   secrets/inference_api_key → your inference provider API key
#
# pydantic-settings reads secrets/neo4j_password, secrets/exa_api_key,
# and secrets/inference_api_key automatically.
# Docker reads secrets/neo4j_auth via NEO4J_AUTH_FILE in docker-compose.yml.
#
# Or set INFERENCE_API_KEY directly in .env (not for production):
# INFERENCE_API_KEY=your-key-here
